# Reference decks — local cache only, not for the public repo
recon/*.key
recon/*.pdf
recon/*.pptx
reference-decks/*.key
reference-decks/*.pdf
reference-decks/*.pptx

# Unpacked reference deck trees + temporary round-trip artifacts
recon/unpacked/
recon/round-trip/
recon/*/
reference-decks/unpacked/
reference-decks/*/

# Generated Python bindings (re-harvest from Keynote.app)
src/kpa/_pb/*/

# Vendored third-party source. We pin via submodule / known commit; we do not
# track an unmodified copy in the public repo.
vendor/

# Raw schema dump (large; reproducible by re-running protodump.py)
schemas/*/raw/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.venv*/
build/
dist/

# macOS
.DS_Store
*.swp

# IDE
.vscode/
.idea/

# Test artifacts
tests/_out/
*.thumbnail.png
